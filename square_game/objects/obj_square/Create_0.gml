// Define a velocidade inicial do quadrado
hspeed = 10;  // Move para a direita
vspeed = -30; // Move para cima

// Configura a gravidade
gravity = 0.1;          // Força da gravidade
gravity_direction = 270; // Direção da gravidade (270 = para baixo)

friction = 0.02;

// Variáveis de distância e pontuação
distance_traveled = 0; // Distância percorrida
score = 0; // Pontuação
score_increment = 1; // Quantidade de pontos por unidade de distância